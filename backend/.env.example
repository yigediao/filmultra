# Copy to backend/.env and replace /ABSOLUTE/PATH/TO/FILMULTRA with your own checkout path.

# Core backend paths
DATABASE_URL=sqlite:////ABSOLUTE/PATH/TO/FILMULTRA/var/runtime/backend/photo_dam.db
PHOTO_LIBRARY_ROOT=/mnt/photo_library
PREVIEW_CACHE_DIR=/ABSOLUTE/PATH/TO/FILMULTRA/var/runtime/backend/preview_cache
FACE_MODELS_DIR=/ABSOLUTE/PATH/TO/FILMULTRA/var/cache/backend/face-models

# Startup behavior
AUTO_CREATE_TABLES=true
AUTO_SCAN_ENABLED=true
AUTO_SCAN_INTERVAL_SECONDS=15
AUTO_SCAN_ON_STARTUP=true

# Optional local inference runtimes
SAM2_PYTHON_BIN=/home/YOUR_USER/miniconda3/envs/sam2-photo/bin/python
SAM3D_BODY_PYTHON_BIN=/home/YOUR_USER/miniconda3/envs/sam3d-body-photo/bin/python
SAM3D_OBJECT_PYTHON_BIN=/home/YOUR_USER/miniconda3/envs/sam3d-body-photo/bin/python

# Optional 3D artifact directories
SAM3D_ARTIFACTS_DIR=/ABSOLUTE/PATH/TO/FILMULTRA/var/artifacts/sam3d-body-runs
SAM3D_PREVIEW_DIR=/ABSOLUTE/PATH/TO/FILMULTRA/var/artifacts/sam3d-body-previews
SAM3D_OBJECT_ARTIFACTS_DIR=/ABSOLUTE/PATH/TO/FILMULTRA/var/artifacts/sam3d-object-runs
SAM3D_OBJECT_PREVIEW_DIR=/ABSOLUTE/PATH/TO/FILMULTRA/var/artifacts/sam3d-object-previews
